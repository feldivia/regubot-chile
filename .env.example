# API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Banco Central de Chile (opcional - registrarse gratis en si3.bcentral.cl)
# Sin estas credenciales, UF/UTM/TPM/dólar/IPC no estarán disponibles
# BCCH_USER=
# BCCH_PASSWORD=

# Base de datos
DATABASE_URL=postgresql://regbot:regbot@localhost:5432/regbot

# Redis (opcional - sin Redis, cache y rate limiting se desactivan)
# REDIS_URL=redis://localhost:6379/0

# Observabilidad
SENTRY_DSN=
LOG_LEVEL=INFO

# Rate limiting
RATE_LIMIT_PER_MIN=20

# Modelos
CLAUDE_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=text-embedding-3-large

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
